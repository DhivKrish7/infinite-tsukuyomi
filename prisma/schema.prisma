generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum KycStatus {
  NOT_STARTED
  PENDING
  IN_REVIEW
  VERIFIED
  FAILED
  FLAGGED
}

enum KycDocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVER_LICENSE
  PROOF_OF_ADDRESS
  BANK_STATEMENT
  SOURCE_OF_FUNDS
  SELFIE
  OTHER
}

enum KycDocumentStatus {
  UPLOADED
  PROCESSING
  ACCEPTED
  REJECTED
  EXPIRED
  NEEDS_RESUBMISSION
}

enum ComplianceReviewStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
  INFORMATION_REQUESTED
}

enum SanctionsScreeningStatus {
  QUEUED
  CLEAR
  POSSIBLE_MATCH
  CONFIRMED_MATCH
  ERROR
}

enum ScreeningProviderStatus {
  DISCONNECTED
  CONNECTED
  DEGRADED
  SUSPENDED
  ERROR
}

enum ComplianceNoteVisibility {
  INTERNAL
  AUDIT
  ESCALATION
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  FEE
  COMMISSION
}

enum TransactionStatus {
  PENDING
  APPROVED
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

enum WalletType {
  CLIENT
  OPERATING
  FEE
  SETTLEMENT
}

enum LedgerEntryDirection {
  DEBIT
  CREDIT
}

enum FinanceApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

enum FinanceApprovalStep {
  REQUEST_REVIEW
  RISK_REVIEW
  FINANCE_REVIEW
  ADMIN_APPROVAL
  RELEASED
}

enum PaymentGatewayStatus {
  DISCONNECTED
  CONNECTED
  DEGRADED
  SUSPENDED
  ERROR
}

enum FinanceFeeType {
  PROCESSING
  NETWORK
  CHARGEBACK
  FX
  WITHDRAWAL
  DEPOSIT
  INTERNAL
}

enum SuspiciousFlagStatus {
  OPEN
  IN_REVIEW
  CLEARED
  ESCALATED
}

enum SuspiciousFlagSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  LOST
}

enum OnboardingStage {
  NEW_LEAD
  CONTACTED
  APPLICATION_STARTED
  KYC_SUBMITTED
  KYC_REVIEW
  APPROVED
  FUNDED
  ACTIVE_TRADER
  STALLED
  REJECTED
}

enum CommunicationType {
  EMAIL
  PHONE
  SMS
  WHATSAPP
  TELEGRAM
  LIVE_CHAT
  MEETING
  SYSTEM
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BrokerConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  DEGRADED
  SUSPENDED
  ERROR
}

enum BrokerSyncType {
  ACCOUNTS
  TRADES
  TRANSACTIONS
  BALANCES
}

enum BrokerSyncStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  clients   Client[]
  leads     Lead[]
  tags      Tag[]
  platforms TradingPlatform[]
  brokerConnections BrokerConnection[]
  brokerSyncRuns     BrokerSyncRun[]
  wallets            Wallet[]
  paymentGateways    PaymentGatewayConnection[]
  financeApprovals   FinanceApproval[]
  ledgerEntries      LedgerEntry[]
  financeFees        FinanceFee[]
  suspiciousFlags    SuspiciousTransactionFlag[]
  gatewayEvents      PaymentGatewayEvent[]
  kycCases           KycCase[]
  kycDocuments       KycDocument[]
  complianceReviews  ComplianceReview[]
  sanctionsScreenings SanctionsScreening[]
  screeningProviders ScreeningProviderConnection[]
  complianceNotes    ComplianceNote[]
  complianceAuditEvents ComplianceAuditEvent[]
}

model User {
  id                  String    @id @default(uuid())
  tenantId            String
  email               String
  name                String
  passwordHash        String
  isActive            Boolean   @default(true)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  userRoles           UserRole[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  assignedClients     Client[]             @relation("ClientAssignedTo")
  assignedLeads       Lead[]               @relation("LeadAssignedTo")
  authoredClientNotes ClientNote[]         @relation("ClientNoteAuthor")
  authoredLeadNotes   LeadNote[]           @relation("LeadNoteAuthor")
  communications      CommunicationLog[]   @relation("CommunicationCreatedBy")
  createdTasks        TaskReminder[]       @relation("TaskCreatedBy")
  assignedTasks       TaskReminder[]       @relation("TaskAssignedTo")
  requestedFinanceTransactions Transaction[] @relation("FinanceTransactionRequestedBy")
  processedFinanceTransactions Transaction[] @relation("FinanceTransactionProcessedBy")
  financeApprovals    FinanceApproval[]    @relation("FinanceApprovalReviewer")
  reviewedSuspiciousFlags SuspiciousTransactionFlag[] @relation("SuspiciousFlagReviewer")
  assignedKycCases    KycCase[]            @relation("KycCaseAssignedReviewer")
  reviewedKycDocuments KycDocument[]       @relation("KycDocumentReviewer")
  complianceReviews   ComplianceReview[]   @relation("ComplianceReviewReviewer")
  authoredComplianceNotes ComplianceNote[]  @relation("ComplianceNoteAuthor")
  complianceAuditEvents ComplianceAuditEvent[] @relation("ComplianceAuditActor")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  userRoles   UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  tokenHash      String    @unique
  familyId       String
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id              String          @id @default(uuid())
  tenantId        String
  platformId      String?
  assignedToId    String?
  convertedLeadId String?
  externalId      String?
  name            String
  email           String
  phone           String?
  country         String?
  language        String?
  status          ClientStatus    @default(PENDING)
  onboardingStage OnboardingStage @default(APPROVED)
  kycStatus       KycStatus       @default(NOT_STARTED)
  riskLevel       RiskLevel       @default(LOW)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  platform       TradingPlatform?   @relation(fields: [platformId], references: [id])
  assignedTo     User?              @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  convertedLead  Lead?              @relation("ConvertedLead", fields: [convertedLeadId], references: [id])
  accounts       TradingAccount[]
  transactions   Transaction[]
  wallets        Wallet[]
  kycCases       KycCase[]
  kycDocuments   KycDocument[]
  sanctionsScreenings SanctionsScreening[]
  complianceNotes ComplianceNote[]
  tags           ClientTag[]
  notes          ClientNote[]
  communications CommunicationLog[]
  tasks          TaskReminder[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, onboardingStage])
  @@index([tenantId, kycStatus])
  @@index([platformId])
  @@index([assignedToId])
}

model Lead {
  id              String          @id @default(uuid())
  tenantId        String
  assignedToId    String?
  name            String
  email           String?
  phone           String?
  country         String?
  source          String?
  campaign        String?
  status          LeadStatus      @default(NEW)
  onboardingStage OnboardingStage @default(NEW_LEAD)
  score           Int             @default(0)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  convertedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  assignedTo      User?              @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  convertedClient Client[]           @relation("ConvertedLead")
  tags            LeadTag[]
  notes           LeadNote[]
  communications  CommunicationLog[]
  tasks           TaskReminder[]

  @@index([tenantId, status])
  @@index([tenantId, onboardingStage])
  @@index([assignedToId])
  @@index([tenantId, email])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#00d4ff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  clients    ClientTag[]
  leads      LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ClientTag {
  clientId String
  tagId    String
  addedAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([tagId])
}

model LeadTag {
  leadId  String
  tagId   String
  addedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@index([tagId])
}

model ClientNote {
  id        String   @id @default(uuid())
  clientId  String
  authorId  String?
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?  @relation("ClientNoteAuthor", fields: [authorId], references: [id])

  @@index([clientId, createdAt])
  @@index([authorId])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  authorId  String?
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation("LeadNoteAuthor", fields: [authorId], references: [id])

  @@index([leadId, createdAt])
  @@index([authorId])
}

model CommunicationLog {
  id          String                 @id @default(uuid())
  tenantId    String
  clientId    String?
  leadId      String?
  createdById String?
  type        CommunicationType
  direction   CommunicationDirection
  subject     String?
  body        String
  occurredAt  DateTime               @default(now())
  createdAt   DateTime               @default(now())

  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead      Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("CommunicationCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, occurredAt])
  @@index([clientId])
  @@index([leadId])
}

model TaskReminder {
  id           String       @id @default(uuid())
  tenantId     String
  clientId     String?
  leadId       String?
  createdById  String?
  assignedToId String?
  title        String
  description  String?
  dueAt        DateTime
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client     Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead       Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy  User?   @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignedTo User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  @@index([tenantId, dueAt])
  @@index([tenantId, status])
  @@index([assignedToId])
  @@index([clientId])
  @@index([leadId])
}

model TradingPlatform {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  type        String
  apiBaseUrl  String?
  isConnected Boolean  @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  clients  Client[]
  accounts TradingAccount[]
  brokerConnections BrokerConnection[]

  @@unique([tenantId, name])
  @@index([tenantId, isConnected])
}

model BrokerConnection {
  id              String                 @id @default(uuid())
  tenantId        String
  platformId      String
  adapterKey      String
  displayName     String
  status          BrokerConnectionStatus @default(DISCONNECTED)
  credentials     Json?
  settings        Json?
  accountCursor   String?
  tradeCursor     String?
  transactionCursor String?
  lastHeartbeatAt DateTime?
  lastAccountSyncAt DateTime?
  lastTradeSyncAt DateTime?
  lastTransactionSyncAt DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  platform TradingPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  syncRuns BrokerSyncRun[]

  @@unique([tenantId, adapterKey, displayName])
  @@index([tenantId, status])
  @@index([platformId])
}

model BrokerSyncRun {
  id           String           @id @default(uuid())
  tenantId     String
  connectionId String
  type         BrokerSyncType
  status       BrokerSyncStatus @default(QUEUED)
  cursorBefore String?
  cursorAfter  String?
  recordsRead  Int              @default(0)
  recordsUpserted Int           @default(0)
  error        String?
  metadata     Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  connection BrokerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, createdAt])
  @@index([connectionId, type, createdAt])
}

model TradingAccount {
  id         String   @id @default(uuid())
  clientId   String
  platformId String
  login      String
  currency   String   @default("USD")
  balance    Decimal  @default(0) @db.Decimal(18, 2)
  equity     Decimal  @default(0) @db.Decimal(18, 2)
  margin     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client          @relation(fields: [clientId], references: [id])
  platform TradingPlatform @relation(fields: [platformId], references: [id])
  trades   Trade[]
  balanceSnapshots AccountBalanceSnapshot[]

  @@unique([platformId, login])
  @@index([clientId])
}

model AccountBalanceSnapshot {
  id        String   @id @default(uuid())
  accountId String
  balance   Decimal  @db.Decimal(18, 2)
  equity    Decimal  @db.Decimal(18, 2)
  margin    Decimal  @db.Decimal(18, 2)
  freeMargin Decimal @default(0) @db.Decimal(18, 2)
  credit    Decimal  @default(0) @db.Decimal(18, 2)
  currency  String   @default("USD")
  capturedAt DateTime @default(now())

  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, capturedAt])
}

model Trade {
  id        String   @id @default(uuid())
  accountId String
  ticket    String
  symbol    String
  side      String
  volume    Decimal  @db.Decimal(18, 4)
  openPrice Decimal  @db.Decimal(18, 6)
  closePrice Decimal? @db.Decimal(18, 6)
  pnl       Decimal  @default(0) @db.Decimal(18, 2)
  openedAt  DateTime
  closedAt  DateTime?

  account TradingAccount @relation(fields: [accountId], references: [id])

  @@unique([accountId, ticket])
  @@index([accountId, openedAt])
}

model Transaction {
  id          String            @id @default(uuid())
  tenantId    String
  clientId    String
  walletId    String?
  gatewayConnectionId String?
  requestedById String?
  processedById String?
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  feeAmount   Decimal           @default(0) @db.Decimal(18, 2)
  netAmount   Decimal           @default(0) @db.Decimal(18, 2)
  currency    String            @default("USD")
  method      String?
  reference   String?
  gatewayReference String?
  riskScore   Int               @default(0)
  suspicious  Boolean           @default(false)
  riskReason  String?
  requestedAt DateTime          @default(now())
  processedAt DateTime?

  client            Client                    @relation(fields: [clientId], references: [id])
  wallet            Wallet?                   @relation(fields: [walletId], references: [id])
  gatewayConnection PaymentGatewayConnection? @relation(fields: [gatewayConnectionId], references: [id])
  requestedBy       User?                     @relation("FinanceTransactionRequestedBy", fields: [requestedById], references: [id])
  processedBy       User?                     @relation("FinanceTransactionProcessedBy", fields: [processedById], references: [id])
  approvals         FinanceApproval[]
  ledgerEntries     LedgerEntry[]
  fees              FinanceFee[]
  suspiciousFlags   SuspiciousTransactionFlag[]

  @@index([tenantId, status])
  @@index([clientId, requestedAt])
  @@index([walletId, requestedAt])
  @@index([gatewayConnectionId])
  @@index([tenantId, suspicious, status])
}

model Wallet {
  id                 String       @id @default(uuid())
  tenantId           String
  clientId           String?
  type               WalletType   @default(CLIENT)
  status             WalletStatus @default(ACTIVE)
  currency           String       @default("USD")
  ledgerBalance      Decimal      @default(0) @db.Decimal(18, 2)
  availableBalance   Decimal      @default(0) @db.Decimal(18, 2)
  holdBalance        Decimal      @default(0) @db.Decimal(18, 2)
  lifetimeDeposits   Decimal      @default(0) @db.Decimal(18, 2)
  lifetimeWithdrawals Decimal     @default(0) @db.Decimal(18, 2)
  providerReference  String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  client        Client?        @relation(fields: [clientId], references: [id])
  transactions  Transaction[]
  ledgerEntries LedgerEntry[]

  @@index([tenantId, status])
  @@index([tenantId, type, currency])
  @@index([clientId])
}

model LedgerEntry {
  id             String               @id @default(uuid())
  tenantId       String
  walletId       String
  transactionId  String?
  direction      LedgerEntryDirection
  entryType      String
  amount         Decimal              @db.Decimal(18, 2)
  currency       String               @default("USD")
  balanceAfter   Decimal              @db.Decimal(18, 2)
  reference      String?
  occurredAt     DateTime             @default(now())
  createdAt      DateTime             @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  wallet      Wallet       @relation(fields: [walletId], references: [id], onDelete: Cascade)
  transaction Transaction? @relation(fields: [transactionId], references: [id])

  @@index([tenantId, occurredAt])
  @@index([walletId, occurredAt])
  @@index([transactionId])
}

model FinanceApproval {
  id            String                @id @default(uuid())
  tenantId      String
  transactionId String
  reviewerId    String?
  step          FinanceApprovalStep
  status        FinanceApprovalStatus @default(PENDING)
  comment       String?
  decidedAt     DateTime?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewer    User?       @relation("FinanceApprovalReviewer", fields: [reviewerId], references: [id])

  @@index([tenantId, status, step])
  @@index([transactionId])
  @@index([reviewerId])
}

model FinanceFee {
  id            String         @id @default(uuid())
  tenantId      String
  transactionId String?
  type          FinanceFeeType
  name          String
  amount        Decimal        @db.Decimal(18, 2)
  currency      String         @default("USD")
  ruleSnapshot  Json?
  createdAt     DateTime       @default(now())

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  transaction Transaction? @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, createdAt])
  @@index([transactionId])
}

model PaymentGatewayConnection {
  id                 String               @id @default(uuid())
  tenantId           String
  key                String
  displayName        String
  provider           String
  status             PaymentGatewayStatus @default(DISCONNECTED)
  settlementCurrency String               @default("USD")
  credentials        Json?
  settings           Json?
  lastHealthCheckAt  DateTime?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  tenant       Tenant                @relation(fields: [tenantId], references: [id])
  transactions Transaction[]
  events       PaymentGatewayEvent[]

  @@unique([tenantId, key])
  @@index([tenantId, status])
}

model PaymentGatewayEvent {
  id                  String   @id @default(uuid())
  tenantId            String
  gatewayConnectionId String
  externalId          String?
  eventType           String
  payload             Json
  processedAt         DateTime?
  createdAt           DateTime @default(now())

  tenant            Tenant                   @relation(fields: [tenantId], references: [id])
  gatewayConnection PaymentGatewayConnection @relation(fields: [gatewayConnectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt])
  @@index([gatewayConnectionId, eventType])
  @@index([externalId])
}

model SuspiciousTransactionFlag {
  id            String                 @id @default(uuid())
  tenantId      String
  transactionId String
  reviewedById  String?
  status        SuspiciousFlagStatus   @default(OPEN)
  severity      SuspiciousFlagSeverity @default(MEDIUM)
  ruleCode      String
  reason        String
  reviewedAt    DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant      Tenant      @relation(fields: [tenantId], references: [id])
  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  reviewedBy  User?       @relation("SuspiciousFlagReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId, status, severity])
  @@index([transactionId])
  @@index([reviewedById])
}

model KycCase {
  id                 String    @id @default(uuid())
  tenantId           String
  clientId           String
  assignedReviewerId String?
  status             KycStatus @default(PENDING)
  riskLevel          RiskLevel @default(LOW)
  riskScore          Int       @default(0)
  riskReason         String?
  workflowStage      String    @default("DOCUMENT_COLLECTION")
  submittedAt        DateTime?
  decidedAt          DateTime?
  expiresAt          DateTime?
  notes              String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant           Tenant               @relation(fields: [tenantId], references: [id])
  client           Client               @relation(fields: [clientId], references: [id])
  assignedReviewer User?                @relation("KycCaseAssignedReviewer", fields: [assignedReviewerId], references: [id])
  documents        KycDocument[]
  reviews          ComplianceReview[]
  screenings       SanctionsScreening[]
  complianceNotes  ComplianceNote[]
  auditEvents      ComplianceAuditEvent[]

  @@index([tenantId, status, riskLevel])
  @@index([tenantId, workflowStage])
  @@index([clientId, status])
  @@index([assignedReviewerId])
}

model KycDocument {
  id              String            @id @default(uuid())
  tenantId        String
  clientId        String
  kycCaseId       String
  reviewedById    String?
  type            KycDocumentType
  status          KycDocumentStatus @default(UPLOADED)
  fileName        String
  mimeType        String
  byteSize        Int
  storageKey      String
  checksum        String?
  rejectionReason String?
  uploadedAt      DateTime          @default(now())
  reviewedAt      DateTime?
  expiresAt       DateTime?

  tenant     Tenant   @relation(fields: [tenantId], references: [id])
  client     Client   @relation(fields: [clientId], references: [id])
  kycCase    KycCase  @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)
  reviewedBy User?    @relation("KycDocumentReviewer", fields: [reviewedById], references: [id])

  @@index([tenantId, status, type])
  @@index([clientId, uploadedAt])
  @@index([kycCaseId])
  @@index([reviewedById])
}

model ComplianceReview {
  id            String                 @id @default(uuid())
  tenantId      String
  kycCaseId     String
  reviewerId    String?
  status        ComplianceReviewStatus @default(PENDING)
  decisionCode  String?
  summary       String?
  checklist     Json?
  decidedAt     DateTime?
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt

  tenant   Tenant  @relation(fields: [tenantId], references: [id])
  kycCase  KycCase @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)
  reviewer User?   @relation("ComplianceReviewReviewer", fields: [reviewerId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([kycCaseId])
  @@index([reviewerId])
}

model ScreeningProviderConnection {
  id                String                  @id @default(uuid())
  tenantId          String
  key               String
  displayName       String
  provider          String
  status            ScreeningProviderStatus @default(DISCONNECTED)
  credentials       Json?
  settings          Json?
  lastHealthCheckAt DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  screenings SanctionsScreening[]

  @@unique([tenantId, key])
  @@index([tenantId, status])
}

model SanctionsScreening {
  id                   String                   @id @default(uuid())
  tenantId             String
  clientId             String
  kycCaseId            String
  providerConnectionId String?
  status               SanctionsScreeningStatus @default(QUEUED)
  riskScore            Int                      @default(0)
  matchCount           Int                      @default(0)
  providerReference    String?
  searchProfile        Json?
  resultPayload        Json?
  screenedAt           DateTime?
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt

  tenant             Tenant                       @relation(fields: [tenantId], references: [id])
  client             Client                       @relation(fields: [clientId], references: [id])
  kycCase            KycCase                      @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)
  providerConnection ScreeningProviderConnection? @relation(fields: [providerConnectionId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([clientId, createdAt])
  @@index([kycCaseId])
  @@index([providerConnectionId])
}

model ComplianceNote {
  id         String                   @id @default(uuid())
  tenantId   String
  clientId   String
  kycCaseId  String?
  authorId   String?
  visibility ComplianceNoteVisibility @default(INTERNAL)
  body       String
  pinned     Boolean                  @default(false)
  createdAt  DateTime                 @default(now())
  updatedAt  DateTime                 @updatedAt

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  client  Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  kycCase KycCase? @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)
  author  User?    @relation("ComplianceNoteAuthor", fields: [authorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([clientId, createdAt])
  @@index([kycCaseId])
  @@index([authorId])
}

model ComplianceAuditEvent {
  id        String   @id @default(uuid())
  tenantId  String
  kycCaseId String?
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  kycCase KycCase? @relation(fields: [kycCaseId], references: [id], onDelete: Cascade)
  actor   User?    @relation("ComplianceAuditActor", fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([kycCaseId, createdAt])
  @@index([entity, entityId])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
}
