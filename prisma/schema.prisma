generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum KycStatus {
  NOT_STARTED
  PENDING
  VERIFIED
  FAILED
  FLAGGED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
  FEE
  COMMISSION
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REJECTED
  CANCELLED
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  NURTURING
  CONVERTED
  LOST
}

enum OnboardingStage {
  NEW_LEAD
  CONTACTED
  APPLICATION_STARTED
  KYC_SUBMITTED
  KYC_REVIEW
  APPROVED
  FUNDED
  ACTIVE_TRADER
  STALLED
  REJECTED
}

enum CommunicationType {
  EMAIL
  PHONE
  SMS
  WHATSAPP
  TELEGRAM
  LIVE_CHAT
  MEETING
  SYSTEM
}

enum CommunicationDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum BrokerConnectionStatus {
  DISCONNECTED
  CONNECTING
  CONNECTED
  DEGRADED
  SUSPENDED
  ERROR
}

enum BrokerSyncType {
  ACCOUNTS
  TRADES
  TRANSACTIONS
  BALANCES
}

enum BrokerSyncStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  clients   Client[]
  leads     Lead[]
  tags      Tag[]
  platforms TradingPlatform[]
  brokerConnections BrokerConnection[]
  brokerSyncRuns     BrokerSyncRun[]
}

model User {
  id                  String    @id @default(uuid())
  tenantId            String
  email               String
  name                String
  passwordHash        String
  isActive            Boolean   @default(true)
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  userRoles           UserRole[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  refreshTokens       RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  assignedClients     Client[]             @relation("ClientAssignedTo")
  assignedLeads       Lead[]               @relation("LeadAssignedTo")
  authoredClientNotes ClientNote[]         @relation("ClientNoteAuthor")
  authoredLeadNotes   LeadNote[]           @relation("LeadNoteAuthor")
  communications      CommunicationLog[]   @relation("CommunicationCreatedBy")
  createdTasks        TaskReminder[]       @relation("TaskCreatedBy")
  assignedTasks       TaskReminder[]       @relation("TaskAssignedTo")

  @@unique([tenantId, email])
  @@index([tenantId])
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  userRoles   UserRole[]
  permissions RolePermission[]
}

model Permission {
  id          String   @id @default(uuid())
  key         String   @unique
  description String?

  roles RolePermission[]
}

model UserRole {
  userId String
  roleId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id             String    @id @default(uuid())
  userId         String
  tokenHash      String    @unique
  familyId       String
  userAgent      String?
  ipAddress      String?
  expiresAt      DateTime
  revokedAt      DateTime?
  replacedByHash String?
  createdAt      DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Client {
  id              String          @id @default(uuid())
  tenantId        String
  platformId      String?
  assignedToId    String?
  convertedLeadId String?
  externalId      String?
  name            String
  email           String
  phone           String?
  country         String?
  language        String?
  status          ClientStatus    @default(PENDING)
  onboardingStage OnboardingStage @default(APPROVED)
  kycStatus       KycStatus       @default(NOT_STARTED)
  riskLevel       RiskLevel       @default(LOW)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant         Tenant             @relation(fields: [tenantId], references: [id])
  platform       TradingPlatform?   @relation(fields: [platformId], references: [id])
  assignedTo     User?              @relation("ClientAssignedTo", fields: [assignedToId], references: [id])
  convertedLead  Lead?              @relation("ConvertedLead", fields: [convertedLeadId], references: [id])
  accounts       TradingAccount[]
  transactions   Transaction[]
  kycCases       KycCase[]
  tags           ClientTag[]
  notes          ClientNote[]
  communications CommunicationLog[]
  tasks          TaskReminder[]

  @@unique([tenantId, email])
  @@index([tenantId, status])
  @@index([tenantId, onboardingStage])
  @@index([tenantId, kycStatus])
  @@index([platformId])
  @@index([assignedToId])
}

model Lead {
  id              String          @id @default(uuid())
  tenantId        String
  assignedToId    String?
  name            String
  email           String?
  phone           String?
  country         String?
  source          String?
  campaign        String?
  status          LeadStatus      @default(NEW)
  onboardingStage OnboardingStage @default(NEW_LEAD)
  score           Int             @default(0)
  lastContactedAt DateTime?
  nextFollowUpAt  DateTime?
  convertedAt     DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  assignedTo      User?              @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  convertedClient Client[]           @relation("ConvertedLead")
  tags            LeadTag[]
  notes           LeadNote[]
  communications  CommunicationLog[]
  tasks           TaskReminder[]

  @@index([tenantId, status])
  @@index([tenantId, onboardingStage])
  @@index([assignedToId])
  @@index([tenantId, email])
}

model Tag {
  id        String   @id @default(uuid())
  tenantId  String
  name      String
  color     String   @default("#00d4ff")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant     Tenant      @relation(fields: [tenantId], references: [id])
  clients    ClientTag[]
  leads      LeadTag[]

  @@unique([tenantId, name])
  @@index([tenantId])
}

model ClientTag {
  clientId String
  tagId    String
  addedAt  DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([clientId, tagId])
  @@index([tagId])
}

model LeadTag {
  leadId  String
  tagId   String
  addedAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leadId, tagId])
  @@index([tagId])
}

model ClientNote {
  id        String   @id @default(uuid())
  clientId  String
  authorId  String?
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  author User?  @relation("ClientNoteAuthor", fields: [authorId], references: [id])

  @@index([clientId, createdAt])
  @@index([authorId])
}

model LeadNote {
  id        String   @id @default(uuid())
  leadId    String
  authorId  String?
  body      String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lead   Lead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  author User? @relation("LeadNoteAuthor", fields: [authorId], references: [id])

  @@index([leadId, createdAt])
  @@index([authorId])
}

model CommunicationLog {
  id          String                 @id @default(uuid())
  tenantId    String
  clientId    String?
  leadId      String?
  createdById String?
  type        CommunicationType
  direction   CommunicationDirection
  subject     String?
  body        String
  occurredAt  DateTime               @default(now())
  createdAt   DateTime               @default(now())

  client    Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead      Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("CommunicationCreatedBy", fields: [createdById], references: [id])

  @@index([tenantId, occurredAt])
  @@index([clientId])
  @@index([leadId])
}

model TaskReminder {
  id           String       @id @default(uuid())
  tenantId     String
  clientId     String?
  leadId       String?
  createdById  String?
  assignedToId String?
  title        String
  description  String?
  dueAt        DateTime
  status       TaskStatus   @default(OPEN)
  priority     TaskPriority @default(MEDIUM)
  completedAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  client     Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  lead       Lead?   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  createdBy  User?   @relation("TaskCreatedBy", fields: [createdById], references: [id])
  assignedTo User?   @relation("TaskAssignedTo", fields: [assignedToId], references: [id])

  @@index([tenantId, dueAt])
  @@index([tenantId, status])
  @@index([assignedToId])
  @@index([clientId])
  @@index([leadId])
}

model TradingPlatform {
  id          String   @id @default(uuid())
  tenantId    String
  name        String
  type        String
  apiBaseUrl  String?
  isConnected Boolean  @default(false)
  lastSyncAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant   Tenant           @relation(fields: [tenantId], references: [id])
  clients  Client[]
  accounts TradingAccount[]
  brokerConnections BrokerConnection[]

  @@unique([tenantId, name])
  @@index([tenantId, isConnected])
}

model BrokerConnection {
  id              String                 @id @default(uuid())
  tenantId        String
  platformId      String
  adapterKey      String
  displayName     String
  status          BrokerConnectionStatus @default(DISCONNECTED)
  credentials     Json?
  settings        Json?
  accountCursor   String?
  tradeCursor     String?
  transactionCursor String?
  lastHeartbeatAt DateTime?
  lastAccountSyncAt DateTime?
  lastTradeSyncAt DateTime?
  lastTransactionSyncAt DateTime?
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  tenant   Tenant          @relation(fields: [tenantId], references: [id])
  platform TradingPlatform @relation(fields: [platformId], references: [id], onDelete: Cascade)
  syncRuns BrokerSyncRun[]

  @@unique([tenantId, adapterKey, displayName])
  @@index([tenantId, status])
  @@index([platformId])
}

model BrokerSyncRun {
  id           String           @id @default(uuid())
  tenantId     String
  connectionId String
  type         BrokerSyncType
  status       BrokerSyncStatus @default(QUEUED)
  cursorBefore String?
  cursorAfter  String?
  recordsRead  Int              @default(0)
  recordsUpserted Int           @default(0)
  error        String?
  metadata     Json?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime         @default(now())

  tenant     Tenant           @relation(fields: [tenantId], references: [id])
  connection BrokerConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([tenantId, type, createdAt])
  @@index([connectionId, type, createdAt])
}

model TradingAccount {
  id         String   @id @default(uuid())
  clientId   String
  platformId String
  login      String
  currency   String   @default("USD")
  balance    Decimal  @default(0) @db.Decimal(18, 2)
  equity     Decimal  @default(0) @db.Decimal(18, 2)
  margin     Decimal  @default(0) @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  client   Client          @relation(fields: [clientId], references: [id])
  platform TradingPlatform @relation(fields: [platformId], references: [id])
  trades   Trade[]
  balanceSnapshots AccountBalanceSnapshot[]

  @@unique([platformId, login])
  @@index([clientId])
}

model AccountBalanceSnapshot {
  id        String   @id @default(uuid())
  accountId String
  balance   Decimal  @db.Decimal(18, 2)
  equity    Decimal  @db.Decimal(18, 2)
  margin    Decimal  @db.Decimal(18, 2)
  freeMargin Decimal @default(0) @db.Decimal(18, 2)
  credit    Decimal  @default(0) @db.Decimal(18, 2)
  currency  String   @default("USD")
  capturedAt DateTime @default(now())

  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, capturedAt])
}

model Trade {
  id        String   @id @default(uuid())
  accountId String
  ticket    String
  symbol    String
  side      String
  volume    Decimal  @db.Decimal(18, 4)
  openPrice Decimal  @db.Decimal(18, 6)
  closePrice Decimal? @db.Decimal(18, 6)
  pnl       Decimal  @default(0) @db.Decimal(18, 2)
  openedAt  DateTime
  closedAt  DateTime?

  account TradingAccount @relation(fields: [accountId], references: [id])

  @@unique([accountId, ticket])
  @@index([accountId, openedAt])
}

model Transaction {
  id          String            @id @default(uuid())
  tenantId    String
  clientId    String
  type        TransactionType
  status      TransactionStatus @default(PENDING)
  amount      Decimal           @db.Decimal(18, 2)
  currency    String            @default("USD")
  method      String?
  reference   String?
  requestedAt DateTime          @default(now())
  processedAt DateTime?

  client Client @relation(fields: [clientId], references: [id])

  @@index([tenantId, status])
  @@index([clientId, requestedAt])
}

model KycCase {
  id         String    @id @default(uuid())
  clientId   String
  status     KycStatus @default(PENDING)
  riskLevel  RiskLevel @default(LOW)
  reviewerId String?
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId, status])
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  actor User? @relation("AuditActor", fields: [actorId], references: [id])

  @@index([tenantId, createdAt])
  @@index([entity, entityId])
}
