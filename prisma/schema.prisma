  id              String                   @id @default(uuid())
  tenantId        String
  campaignId      String?
  leadId          String?
  clientId        String?
  type            MarketingAttributionType
  source          String
  medium          String?
  touchpoint      String
  landingPage     String?
  referrer        String?
  conversionValue Decimal                  @default(0) @db.Decimal(18, 2)
  occurredAt      DateTime                 @default(now())
  metadata        Json?
  createdAt       DateTime                 @default(now())

  tenant           Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  campaign         MarketingCampaign? @relation("CampaignAttributions", fields: [campaignId], references: [id], onDelete: SetNull)
  lead             Lead?              @relation("MarketingAttributionLead", fields: [leadId], references: [id], onDelete: SetNull)
  client           Client?            @relation("MarketingAttributionClient", fields: [clientId], references: [id], onDelete: SetNull)
